#cloud-config
users:
  - name: ubuntu
    groups: [sudo, docker]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ${ssh_public_key}
package_update: true
package_upgrade: true
packages:
  - docker.io
runcmd:
  - |
    docker run -d --restart=always --name=${container_name} \
    -p 80:80 \
    ${container_image}
